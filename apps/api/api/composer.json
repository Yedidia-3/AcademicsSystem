{
    "name": "jericho/academics-system",
    "description": "Laravel backend for Jericho School Management",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "ext-json": "*",
        "ext-pdo": "*",
        "laravel/framework": "^10.0",
        "laravel/sanctum": "^3.2",

        "barryvdh/laravel-dompdf": "^2.0",
        "spatie/laravel-permission": "^5.10"
    },
    "require-dev": {
        "fakerphp/faker": "^1.21",
        "phpunit/phpunit": "^10.0",
        "nunomaduro/collision": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "test": "phpunit"
    }
}
